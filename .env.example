# Contact form email (Resend) — used by app/api/contact/route.ts
# Copy this file to `.env.local` for development, and set the same vars in Vercel for prod.

# Required: your Resend API key (https://resend.com/api-keys)
RESEND_API_KEY=

# Optional: where contact messages are delivered. Defaults to SITE.email (contact@danielfalzon.mt).
CONTACT_TO_EMAIL=contact@danielfalzon.mt

# Optional: a VERIFIED Resend sender. Until you verify a domain in Resend, leave this unset
# to use Resend's sandbox sender (which can only deliver to your own Resend account email).
# Once danielfalzon.mt is verified in Resend, e.g.:
# CONTACT_FROM_EMAIL="Daniel Falzon <hello@danielfalzon.mt>"
CONTACT_FROM_EMAIL=
